rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128;
    }

    function isValidEvent(data) {
      return data.keys().hasAll(['title', 'theme', 'date', 'revenue', 'expense', 'attendees', 'creatorUid'])
        && data.title is string && data.title.size() >= 3 && data.title.size() <= 100
        && data.theme is string
        && data.date is string
        && data.revenue is number && data.revenue >= 0
        && data.expense is number && data.expense >= 0
        && data.attendees is number && data.attendees >= 0
        && data.creatorUid is string;
    }

    match /events/{eventId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && isValidId(eventId) && isValidEvent(request.resource.data);
      allow update: if request.auth != null && isValidId(eventId) && isValidEvent(request.resource.data);
      allow delete: if request.auth != null;
    }
  }
}
